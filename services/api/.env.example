NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql://llc_code:REPLACE_WITH_LOCAL_DB_PASSWORD@localhost:55432/llc_code?schema=public
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=GENERATE_A_PRIVATE_RANDOM_SECRET_OF_AT_LEAST_32_CHARACTERS
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_PRIVATE_RANDOM_SECRET
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Optional: used only by npm.cmd run db:seed
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Required only by the standalone judge worker.
# This must point to a separately isolated, self-hosted sandbox service.
JUDGE_ENGINE_PROVIDER=piston
JUDGE_ENGINE_URL=http://localhost:2000
# Required only when JUDGE_ENGINE_PROVIDER=contract.
JUDGE_ENGINE_SECRET=GENERATE_A_PRIVATE_WORKER_TO_ENGINE_SECRET
JUDGE_WORKER_CONCURRENCY=2
JUDGE_MAX_OUTPUT_KB=256
